{
  "name": "lightning-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:embed": "vite build --config vite.embed.config.ts",
    "build:workbench": "vite build --config vite.workbench.config.ts",
    "build:all": "npm run build:embed && npm run build:workbench",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@protobuf-ts/runtime": "^2.11.1",
    "jszip": "^3.10.1",
    "pako": "^2.1.0",
    "snarkdown": "^2.0.0",
    "three": "^0.174.0",
    "vue": "^3.5.13"
  },
  "version": "0.0.0",
  "description": "Lightning web frontend — 3D structure viewer and workbench",
  "devDependencies": {
    "@types/pako": "^2.0.4",
    "@types/three": "^0.174.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "jsdom": "^29.1.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.6",
    "vue-tsc": "^2.2.0"
  }
}
